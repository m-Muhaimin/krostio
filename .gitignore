# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env*.local
.env.production
.env.development
.env.vercel
.env.local.bak
# but keep .env.example as a template reference
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Hardhat / blockchain artifacts
blockchain/cache/
blockchain/artifacts/
blockchain/typechain-types/
blockchain/node_modules/
blockchain/pnpm-lock.yaml
blockchain/pnpm-workspace.yaml
blockchain/keystore.json
blockchain/deployments/
